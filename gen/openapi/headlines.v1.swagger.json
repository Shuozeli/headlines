{
  "swagger": "2.0",
  "info": {
    "title": "headlines API",
    "version": "v1",
    "description": "Hand-rolled OpenAPI 2.0 (Swagger) descriptor for the headlines REST gateway. v1 covers AccountService illustratively; the full surface (UserService, ArticleService, DraftService, FollowService, FeedRecommendationService, FeedFollowService, AccountStreamService, EventService, NotificationService) is exposed in JSON via the same /v1/... routes documented in docs/design/api-conventions.md and the per-service docs/design/<service>.md. See docs/implementation-issues.md entry [8] for the placeholder note pending the full `buf generate`-emitted spec.",
    "contact": {
      "name": "headlines"
    }
  },
  "schemes": ["http", "https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "tags": [
    {"name": "AccountService", "description": "Publisher identity. See docs/design/accounts.md."},
    {"name": "UserService", "description": "Consumer identity. See docs/design/users.md."},
    {"name": "ArticleService", "description": "Telegraph-shaped content. See docs/design/articles.md."},
    {"name": "DraftService", "description": "Private working space. See docs/design/drafts.md."},
    {"name": "FollowService", "description": "User→Account follow edges. See docs/design/follows.md."},
    {"name": "FeedRecommendationService", "description": "Ranker-pushed feed. See docs/design/feed-recommendation.md."},
    {"name": "FeedFollowService", "description": "Computed follow feed. See docs/design/feed-follow.md."},
    {"name": "AccountStreamService", "description": "Republisher per-account firehose. See docs/design/account-stream.md."},
    {"name": "EventService", "description": "User-activity log. See docs/design/events.md."},
    {"name": "NotificationService", "description": "Reserved (UNIMPLEMENTED in v1). See docs/design/notifications.md."}
  ],
  "paths": {
    "/v1/accounts": {
      "post": {
        "tags": ["AccountService"],
        "operationId": "AccountService_CreateAccount",
        "summary": "Mint a new account + initial key.",
        "description": "Authorization: bootstrap=open allows Anonymous; bootstrap=system_only requires System with scope `accounts.write`.",
        "parameters": [{
          "in": "body",
          "name": "body",
          "required": true,
          "schema": {"$ref": "#/definitions/v1CreateAccountRequest"}
        }],
        "responses": {
          "200": {"description": "OK", "schema": {"$ref": "#/definitions/v1CreateAccountResponse"}},
          "default": {"description": "error", "schema": {"$ref": "#/definitions/rpcStatus"}}
        }
      }
    },
    "/v1/accounts/{id}": {
      "get": {
        "tags": ["AccountService"],
        "operationId": "AccountService_GetAccount",
        "summary": "Read an account row (Anonymous-readable).",
        "parameters": [{"in": "path", "name": "id", "required": true, "type": "string"}],
        "responses": {
          "200": {"description": "OK", "schema": {"$ref": "#/definitions/v1Account"}},
          "default": {"description": "error", "schema": {"$ref": "#/definitions/rpcStatus"}}
        }
      },
      "patch": {
        "tags": ["AccountService"],
        "operationId": "AccountService_UpdateAccount",
        "summary": "Update an account (AccountSelf, or System with `accounts.write`).",
        "parameters": [
          {"in": "path", "name": "id", "required": true, "type": "string"},
          {"in": "body", "name": "body", "required": true, "schema": {"$ref": "#/definitions/v1UpdateAccountRequest"}}
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"$ref": "#/definitions/v1Account"}},
          "default": {"description": "error", "schema": {"$ref": "#/definitions/rpcStatus"}}
        }
      },
      "delete": {
        "tags": ["AccountService"],
        "operationId": "AccountService_DeleteAccount",
        "summary": "Soft-delete an account (AccountSelf, or System with `accounts.delete`).",
        "parameters": [{"in": "path", "name": "id", "required": true, "type": "string"}],
        "responses": {
          "200": {"description": "OK"},
          "default": {"description": "error", "schema": {"$ref": "#/definitions/rpcStatus"}}
        }
      }
    },
    "/v1/accounts/{id}/keys": {
      "post": {
        "tags": ["AccountService"],
        "operationId": "AccountService_AddAccountKey",
        "summary": "Add a new public key to an account.",
        "parameters": [
          {"in": "path", "name": "id", "required": true, "type": "string"},
          {"in": "body", "name": "body", "required": true, "schema": {"$ref": "#/definitions/v1AddAccountKeyRequest"}}
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"$ref": "#/definitions/v1AccountKey"}},
          "default": {"description": "error", "schema": {"$ref": "#/definitions/rpcStatus"}}
        }
      }
    },
    "/v1/accounts/{id}/keys/{key_id}/revoke": {
      "post": {
        "tags": ["AccountService"],
        "operationId": "AccountService_RevokeAccountKey",
        "summary": "Revoke an account key (lockout-protected — last active key cannot be revoked except by System with `accounts.admin`).",
        "parameters": [
          {"in": "path", "name": "id", "required": true, "type": "string"},
          {"in": "path", "name": "key_id", "required": true, "type": "string"}
        ],
        "responses": {
          "200": {"description": "OK", "schema": {"$ref": "#/definitions/v1AccountKey"}},
          "default": {"description": "error", "schema": {"$ref": "#/definitions/rpcStatus"}}
        }
      }
    },
    "/openapi.json": {
      "get": {
        "tags": ["meta"],
        "operationId": "GetOpenAPI",
        "summary": "Returns this OpenAPI document. Anonymous-readable.",
        "responses": {
          "200": {"description": "OK"}
        }
      }
    }
  },
  "definitions": {
    "v1AccountStatus": {
      "type": "string",
      "enum": ["ACCOUNT_STATUS_UNSPECIFIED", "ACCOUNT_STATUS_ACTIVE", "ACCOUNT_STATUS_DELETED"]
    },
    "v1KeyStatus": {
      "type": "string",
      "enum": ["KEY_STATUS_UNSPECIFIED", "KEY_STATUS_ACTIVE", "KEY_STATUS_REVOKED"]
    },
    "v1Account": {
      "type": "object",
      "properties": {
        "id": {"type": "string"},
        "short_name": {"type": "string"},
        "author_name": {"type": "string"},
        "author_url": {"type": "string"},
        "status": {"$ref": "#/definitions/v1AccountStatus"},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"},
        "deleted_at": {"type": "string", "format": "date-time"}
      }
    },
    "v1AccountKey": {
      "type": "object",
      "properties": {
        "account_id": {"type": "string"},
        "key_id": {"type": "string"},
        "algo": {"type": "string"},
        "public_key": {"type": "string", "description": "base64-encoded raw public key bytes"},
        "status": {"$ref": "#/definitions/v1KeyStatus"},
        "created_at": {"type": "string", "format": "date-time"},
        "revoked_at": {"type": "string", "format": "date-time"}
      }
    },
    "v1PublicKey": {
      "type": "object",
      "properties": {
        "algo": {"type": "string"},
        "public_key": {"type": "string", "description": "base64-encoded raw public key bytes"}
      }
    },
    "v1CreateAccountRequest": {
      "type": "object",
      "properties": {
        "short_name": {"type": "string"},
        "author_name": {"type": "string"},
        "author_url": {"type": "string"},
        "initial_key": {"$ref": "#/definitions/v1PublicKey"}
      }
    },
    "v1CreateAccountResponse": {
      "type": "object",
      "properties": {
        "account": {"$ref": "#/definitions/v1Account"},
        "initial_key": {"$ref": "#/definitions/v1AccountKey"}
      }
    },
    "v1UpdateAccountRequest": {
      "type": "object",
      "properties": {
        "short_name": {"type": "string"},
        "author_name": {"type": "string"},
        "author_url": {"type": "string"}
      }
    },
    "v1AddAccountKeyRequest": {
      "type": "object",
      "properties": {
        "account_id": {"type": "string"},
        "new_key": {"$ref": "#/definitions/v1PublicKey"}
      }
    },
    "rpcStatus": {
      "type": "object",
      "description": "google.rpc.Status with details (typically containing google.rpc.ErrorInfo).",
      "properties": {
        "code": {"type": "integer", "format": "int32"},
        "message": {"type": "string"},
        "details": {"type": "array", "items": {"type": "object"}}
      }
    }
  },
  "securityDefinitions": {
    "SignedRequest": {
      "type": "apiKey",
      "in": "header",
      "name": "Authorization",
      "description": "`Signature key_id=<uuid>, algo=<algo>, ts=<u64>, nonce=<base64>, sig=<base64>`. See docs/design/auth.md."
    }
  }
}
